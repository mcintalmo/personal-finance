# Copy to .env.local and edit. .env.local is gitignored — never commit it.
# Nested settings groups are addressed by prefix: APP_DEBUG -> settings.app.debug
# See src/personal_finance/config.py for all settings and defaults.

# ── Application (settings.app.*) ─────────────────────────────
APP_ENV=development         # development | staging | production
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# ── Paths ────────────────────────────────────────────────────
CONFIG_DIR=config           # user-editable YAML config (see config/README.md)

# ── Data platform (settings.data.*) ──────────────────────────
DATA_WAREHOUSE_PATH=data/warehouse.duckdb   # shared with dbt (transform/profiles.yml)
DATA_BRONZE_PATH=data/bronze                # append-only Parquet landing zone (pf ingest)

# ── Local LLM (settings.ollama.*) ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text     # pull first: `ollama pull nomic-embed-text`
OLLAMA_CHAT_MODEL=phi3:mini                 # LLM-fallback categorization stage; pull first
