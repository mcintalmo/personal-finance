# =============================================================
# Python .gitignore — based on github.com/github/gitignore
# Project-specific additions marked with ★
# =============================================================

# ── Byte-compiled / optimized / DLL files ────────────────────
__pycache__/
*.py[cod]
*$py.class

# ── C extensions ─────────────────────────────────────────────
*.so

# ── Distribution / packaging ──────────────────────────────────
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── PyInstaller ───────────────────────────────────────────────
*.manifest
*.spec

# ── Installer logs ────────────────────────────────────────────
pip-log.txt
pip-delete-this-directory.txt

# ── Unit test / coverage reports ─────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# ── Translations ──────────────────────────────────────────────
*.mo
*.pot

# ── Django ────────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# ── Flask ─────────────────────────────────────────────────────
instance/
.webassets-cache

# ── Scrapy ───────────────────────────────────────────────────
.scrapy

# ── Sphinx documentation ──────────────────────────────────────
docs/_build/

# ── PyBuilder ─────────────────────────────────────────────────
.pybuilder/
target/

# ── Jupyter Notebook ──────────────────────────────────────────
.ipynb_checkpoints

# ── IPython ───────────────────────────────────────────────────
profile_default/
ipython_config.py

# ── pyenv ─────────────────────────────────────────────────────
# Uncomment to ignore .python-version (usually worth committing for uv projects)
#.python-version

# ── pipenv ────────────────────────────────────────────────────
#Pipfile.lock

# ── poetry ────────────────────────────────────────────────────
#poetry.lock

# ── pdm ───────────────────────────────────────────────────────
.pdm.toml
.pdm-python
.pdm-build/

# ── PEP 582 ───────────────────────────────────────────────────
__pypackages__/

# ── Celery ────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── SageMath ──────────────────────────────────────────────────
*.sage.py

# ── Environments ──────────────────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Spyder ────────────────────────────────────────────────────
.spyderproject.db
.spyproject

# ── Rope ──────────────────────────────────────────────────────
.ropeproject

# ── mkdocs ────────────────────────────────────────────────────
/site

# ── mypy ──────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Pyre type checker ─────────────────────────────────────────
.pyre/

# ── pytype ────────────────────────────────────────────────────
.pytype/

# ── Cython debug symbols ──────────────────────────────────────
cython_debug/

# ── JetBrains / PyCharm ───────────────────────────────────────
.idea/

# =============================================================
# ★ Project-specific additions
# =============================================================

# ── uv (★) ───────────────────────────────────────────────────
# uv.lock is intentionally COMMITTED for reproducible installs.
# Remove the line below if you want to ignore it (library authors sometimes do).
# uv.lock
.uv/

# ── Ruff (★) ──────────────────────────────────────────────────
.ruff_cache/

# ── ty type checker (★) ───────────────────────────────────────
.ty_cache/
.pyright/

# ── Environment / secrets (★) ────────────────────────────────
.env.*
# keep the example template committed (no inline comments — gitignore reads them as part of the pattern)
!.env.example
*.local

# ── OS (★) ───────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor (★) ────────────────────────────────────────────────
.vscode/
*.swp
*.swo
*~
.project
.classpath

# ── Terraform (★) ─────────────────────────────────────────────
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.*
infra/terraform/*.tfplan
infra/terraform/.terraform.lock.hcl

# ── Claude Code (★) ───────────────────────────────────────────
.claude/settings.local.json   # personal overrides — never commit

# ── User configuration ──────────────────────────────────────
# Live config may describe real accounts/finances — never commit it.
# Copy config/examples/*.yaml into config/ and edit (see config/README.md).
config/*.yaml

# ── Data warehouse / dbt ────────────────────────────────────
data/
*.duckdb
*.duckdb.wal
transform/target/
transform/dbt_packages/
transform/logs/
transform/.user.yml
